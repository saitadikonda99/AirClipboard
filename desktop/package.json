{
  "name": "airclipboard",
  "version": "1.0.0",
  "description": "Universal Clipboard sync between Android and macOS",
  "type": "module",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"webpack --watch --config webpack.renderer.config.cjs --watch-options-poll 1000\" \"wait-on dist/renderer.js && cp src/renderer/index.html dist/index.html && electron .\"",
    "build:renderer": "webpack --config webpack.renderer.config.cjs && cp src/renderer/index.html dist/index.html",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "keywords": [
    "clipboard",
    "sync",
    "lan",
    "android",
    "macos"
  ],
  "author": "Clippr",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "style-loader": "^3.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "bonjour-service": "^1.1.1",
    "clipboardy": "^4.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.airclipboard.app",
    "productName": "AirClipboard",
    "mac": {
      "target": "dir",
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/renderer/**/*",
      "src/shared/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main/index.js"
    }
  }
}
