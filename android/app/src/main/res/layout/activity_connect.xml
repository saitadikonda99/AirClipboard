<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorPrimary"
        android:paddingTop="48dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@android:color/transparent"
                android:tint="#FFFFFF"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Connect to Mac"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="4dp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Scan QR -->
            <Button
                android:id="@+id/btnScanQr"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:text="Scan QR Code from Mac"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/colorPrimary"
                android:stateListAnimator="@null"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">

                <View android:layout_width="0dp" android:layout_height="0.5dp" android:layout_weight="1" android:background="#E8E8E8" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  or enter manually  " android:textSize="12sp" android:textColor="#9B9B9B" />
                <View android:layout_width="0dp" android:layout_height="0.5dp" android:layout_weight="1" android:background="#E8E8E8" />
            </LinearLayout>

            <!-- IP Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="MAC IP ADDRESS"
                android:textSize="11sp"
                android:textColor="#6B6B6B"
                android:letterSpacing="0.06"
                android:fontFamily="sans-serif-medium" />

            <!-- Input card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card">

                <EditText
                    android:id="@+id/etIp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="192.168.x.x"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#C0C0C0"
                    android:inputType="textNoSuggestions"
                    android:background="@android:color/transparent"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:fontFamily="monospace"
                    android:singleLine="true" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#E8E8E8" android:layout_marginStart="16dp" />

                <EditText
                    android:id="@+id/etPort"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Port"
                    android:text="8585"
                    android:textSize="16sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#C0C0C0"
                    android:inputType="number"
                    android:background="@android:color/transparent"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:fontFamily="monospace"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Connect -->
            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:text="Connect"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/colorPrimary"
                android:stateListAnimator="@null"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- How-to card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOW TO FIND YOUR MAC'S IP"
                    android:textSize="11sp"
                    android:textColor="#6B6B6B"
                    android:letterSpacing="0.06"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <TextView android:text="1  Open AirClipboard on your Mac" android:textSize="13sp" android:textColor="#3C3C43"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:lineSpacingMultiplier="1.3"/>
                <TextView android:text="2  Go to the Connect tab" android:textSize="13sp" android:textColor="#3C3C43"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:lineSpacingMultiplier="1.3"/>
                <TextView android:text="3  Scan the QR code or copy the IP" android:textSize="13sp" android:textColor="#3C3C43"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp" android:lineSpacingMultiplier="1.3"/>
                <TextView android:text="4  Accept the pair request on Mac" android:textSize="13sp" android:textColor="#3C3C43"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
